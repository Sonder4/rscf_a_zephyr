menu "RSCF Services"

config RSCF_EVENT_BUS
  bool "Enable RSCF event bus"
  default y

config RSCF_DAEMON_SERVICE
  bool "Enable RSCF daemon service"
  default y

config RSCF_HEALTH_SERVICE
  bool "Enable RSCF health service"
  default y

config RSCF_LED_STATUS
  bool "Enable RSCF LED status driver"
  default y

config RSCF_EXT_UART_MUX
  bool "Enable RSCF external UART mux driver"
  default y

config RSCF_BUZZER
  bool "Enable RSCF buzzer driver"
  default y

config RSCF_POWER_SWITCH
  bool "Enable RSCF power switch driver"
  default y

config RSCF_COMM_SERVICE
  bool "Enable RSCF communication service"
  default y

config RSCF_ROS_BACKEND_MICROROS
  bool "Use micro-ROS as ROS backend"
  default n

config RSCF_MICROROS_SERVICE
  bool "Enable RSCF micro-ROS service"
  default y
  depends on RSCF_ROS_BACKEND_MICROROS

config RSCF_MICROROS_SIM_MODE
  bool "Enable micro-ROS simulated odom/imu data"
  default y
  depends on RSCF_MICROROS_SERVICE

config RSCF_MICROROS_ODOM_RATE_HZ
  int "micro-ROS odom publish rate (Hz)"
  range 1 1000
  default 200
  depends on RSCF_MICROROS_SERVICE

config RSCF_MICROROS_CMD_RATE_HZ
  int "micro-ROS command loop rate (Hz)"
  range 1 1000
  default 200
  depends on RSCF_MICROROS_SERVICE

config RSCF_MICROROS_STATUS_RATE_HZ
  int "micro-ROS status publish rate (Hz)"
  range 1 1000
  default 20
  depends on RSCF_MICROROS_SERVICE

config RSCF_CHASSIS_SERVICE
  bool "Enable RSCF chassis service"
  default y

config RSCF_ROBOT_SERVICE
  bool "Enable RSCF robot service"
  default y

config RSCF_MOTOR_SERVICE
  bool "Enable RSCF motor service"
  default y

config RSCF_DTOF2510
  bool "Enable RSCF DTOF2510 service"
  default y

config RSCF_IMU_UART
  bool "Enable RSCF IMU UART bridge"
  default y

config RSCF_DEBUG_FAULT
  bool "Enable RSCF debug fault service"
  default n

endmenu
