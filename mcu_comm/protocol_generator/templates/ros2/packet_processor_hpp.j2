template<typename T>
void PacketProcessor::handlePacketTemplate(const PacketData& data,
                                           std::function<void(const T&)> callback) {
    std::lock_guard<std::mutex> lock(handler_mutex_);
    if (!handler_) {
        return;
    }

    if (data.size() >= sizeof(T)) {
        T msg;
        memcpy(&msg, data.data(), sizeof(T));
        callback(msg);
    }
}

