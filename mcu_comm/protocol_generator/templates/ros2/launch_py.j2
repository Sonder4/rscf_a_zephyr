from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument
from launch.substitutions import LaunchConfiguration
from launch_ros.actions import Node
from launch_ros.parameter_descriptions import ParameterValue


def _bool_to_launch(value):
    return "true" if value else "false"


def generate_launch_description():
    serial_port_default = "{{ mcu_device.pc_comm.serial_port if mcu_device.pc_comm is defined and mcu_device.pc_comm.serial_port is defined else (transport_config.ros2.device_path if transport_config.ros2 is defined and transport_config.ros2.device_path is defined else '/dev/ttyACM0') }}"
    baud_rate_default = "{{ (mcu_device.pc_comm.baudrate if mcu_device.pc_comm.baudrate is defined else mcu_device.baudrate) if mcu_device.baudrate is defined else 115200 }}"
    debug_enabled_default = "{{ "true" if mcu_device.pc_comm is defined and mcu_device.pc_comm.debug_enabled is defined and mcu_device.pc_comm.debug_enabled else "false" }}"

    launch_args = [
        DeclareLaunchArgument("device_mid", default_value="{{ mcu_device.mid | hex_to_int }}",
                              description="Target MCU device MID"),
        DeclareLaunchArgument("port_name", default_value=serial_port_default,
                              description="Serial port name"),
        DeclareLaunchArgument("baud_rate", default_value=baud_rate_default,
                              description="Serial baud rate"),
        DeclareLaunchArgument("auto_reconnect", default_value="true",
                              description="Enable auto reconnect"),
        DeclareLaunchArgument("reconnect_interval_ms", default_value="2000",
                              description="Reconnect interval in milliseconds"),
        DeclareLaunchArgument("debug_enabled", default_value=debug_enabled_default,
                              description="Enable debug logging"),
        DeclareLaunchArgument("imu_frame_id", default_value="imu_link",
                              description="IMU frame ID"),
        DeclareLaunchArgument("odom_frame_id", default_value="odom",
                              description="Odometry frame ID"),
        DeclareLaunchArgument("child_frame_id", default_value="base_link",
                              description="Child frame ID")
    ]

    mcu_comm_node = Node(
        package="mcu_comm",
        executable="mcu_comm_node",
        name="{{ mcu_device.ros2_node_name }}",
        output="screen",
        parameters=[{
            "device_mid": ParameterValue(LaunchConfiguration("device_mid"), value_type=int),
            "port_name": LaunchConfiguration("port_name"),
            "baud_rate": ParameterValue(LaunchConfiguration("baud_rate"), value_type=int),
            "auto_reconnect": ParameterValue(LaunchConfiguration("auto_reconnect"), value_type=bool),
            "reconnect_interval_ms": ParameterValue(LaunchConfiguration("reconnect_interval_ms"), value_type=int),
            "debug_enabled": ParameterValue(LaunchConfiguration("debug_enabled"), value_type=bool),
            "imu_frame_id": LaunchConfiguration("imu_frame_id"),
            "odom_frame_id": LaunchConfiguration("odom_frame_id"),
            "child_frame_id": LaunchConfiguration("child_frame_id")
        }],
    )

    return LaunchDescription([*launch_args, mcu_comm_node])
