bool CommManager::isConnected() const {
    return is_connected_;
}

void CommManager::getStats(uint32_t& tx_count, uint32_t& rx_count, uint32_t& error_count) const {
    tx_count = tx_count_.load();
    rx_count = rx_count_.load();
    error_count = error_count_.load();
}

/* ============================================================================ */
/*                              内部线程函数                                    */
/* ============================================================================ */

void CommManager::receiveLoop() {
    constexpr size_t BUFFER_SIZE = 256;
    uint8_t buffer[BUFFER_SIZE];
    
    while (is_running_) {
        if (!transport_->isConnected()) {
            if (is_connected_) {
                updateConnectionStatus(false);
            }
            std::this_thread::sleep_for(std::chrono::milliseconds(100));
            continue;
        }
        
        size_t bytes_read = transport_->read(buffer, BUFFER_SIZE);
        
        if (bytes_read > 0) {
            auto frames = parser_->parse(buffer, bytes_read);
            
            {
                std::lock_guard<std::mutex> lock(queue_mutex_);
                for (const auto& frame : frames) {
                    receive_queue_.push(frame);
                }
            }
            
            queue_cv_.notify_one();
            
            if (!frames.empty()) {
                rx_count_ += frames.size();
            }
        }
    }
}

void CommManager::processLoop() {
    while (is_running_) {
        std::unique_lock<std::mutex> lock(queue_mutex_);
        
        queue_cv_.wait(lock, [this] {
            return !receive_queue_.empty() || !is_running_;
        });
        
        while (!receive_queue_.empty()) {
            auto frame = receive_queue_.front();
            receive_queue_.pop();
            lock.unlock();
            
            dispatchFrame(frame);
            
            lock.lock();
        }
    }
}

void CommManager::heartbeatLoop() {
    while (is_running_) {
        // 每500ms发送一次心跳
        std::this_thread::sleep_for(std::chrono::milliseconds(500));
        
        if (!is_running_) {
            break;
        }

        if (!transport_->isConnected()) {
            if (is_connected_) {
                updateConnectionStatus(false);
            }
            continue;
        }
        
        // 发送心跳包
        if (is_connected_) {
            sendHeartbeat();
        }
    }
}

void CommManager::dispatchFrame(const ProtocolFrame& frame) {
    std::lock_guard<std::mutex> lock(callback_mutex_);
    
    auto it = callbacks_.find(static_cast<PacketID>(frame.pid));
    if (it != callbacks_.end() && it->second) {
        it->second(frame.data);
    }
}

void CommManager::updateConnectionStatus(bool connected) {
    if (is_connected_ != connected) {
        is_connected_ = connected;
        
        std::lock_guard<std::mutex> lock(callback_mutex_);
        if (connection_callback_) {
            connection_callback_(connected);
        }
    }
}

