/* ============================================================================ */
/*                              构造函数/析构函数                               */
/* ============================================================================ */

CommManager::CommManager(std::shared_ptr<ITransport> transport,
                         std::shared_ptr<ProtocolParser> parser)
    : transport_(std::move(transport)),
      parser_(std::move(parser)) {
}

CommManager::~CommManager() {
    stop();
}

/* ============================================================================ */
/*                              初始化/启动/停止                                */
/* ============================================================================ */

bool CommManager::initialize() {
    if (!transport_ || !parser_) {
        std::cerr << "CommManager: transport or parser is null" << std::endl;
        return false;
    }
    
    return true;
}

bool CommManager::start() {
    if (is_running_) {
        return true;
    }
    
    // 连接传输层
    if (!transport_->connect()) {
        std::cerr << "CommManager: failed to connect transport" << std::endl;
        return false;
    }
    
    is_running_ = true;
    
    // 启动接收线程
    receive_thread_ = std::thread(&CommManager::receiveLoop, this);
    
    // 启动处理线程
    process_thread_ = std::thread(&CommManager::processLoop, this);
    
    // 启动心跳线程
    heartbeat_thread_ = std::thread(&CommManager::heartbeatLoop, this);

    updateConnectionStatus(true);
    
    return true;
}

void CommManager::stop() {
    is_running_ = false;
    
    queue_cv_.notify_all();
    
    if (receive_thread_.joinable()) {
        receive_thread_.join();
    }
    
    if (process_thread_.joinable()) {
        process_thread_.join();
    }
    
    if (heartbeat_thread_.joinable()) {
        heartbeat_thread_.join();
    }
    
    if (transport_) {
        transport_->disconnect();
    }
    
    updateConnectionStatus(false);
}

/* ============================================================================ */
/*                              回调注册                                        */
/* ============================================================================ */

void CommManager::registerCallback(PacketID pid, PacketCallback callback) {
    std::lock_guard<std::mutex> lock(callback_mutex_);
    callbacks_[pid] = std::move(callback);
}

void CommManager::registerConnectionCallback(ConnectionCallback callback) {
    std::lock_guard<std::mutex> lock(callback_mutex_);
    connection_callback_ = std::move(callback);
}

/* ============================================================================ */
/*                              发送函数                                        */
/* ============================================================================ */

bool CommManager::sendFrame(PacketID pid, DeviceID mid, const std::vector<uint8_t>& data) {
    if (!is_running_ || !is_connected_) {
        return false;
    }
    
    auto frame = parser_->buildFrame(pid, mid, data);
    frame.heart = heartbeat_counter_++;
    
    auto serialized = frame.serialize();
    
    if (transport_->write(serialized.data(), serialized.size())) {
        tx_count_++;
        return true;
    }
    
    error_count_++;
    if (!transport_->isConnected()) {
        updateConnectionStatus(false);
    }
    return false;
}

