#include "transport/can_transport.hpp"
#include "usb_can.h"

#include <algorithm>
#include <cerrno>
#include <cstring>
#include <string>

namespace mcu_comm {
namespace {

uint8_t crc8_compute(const uint8_t* data, size_t len)
{
    uint8_t crc = 0xffU;

    for (size_t index = 0; index < len; ++index) {
        crc ^= data[index];
        for (uint8_t bit = 0; bit < 8U; ++bit) {
            if ((crc & 0x80U) != 0U) {
                crc = static_cast<uint8_t>((crc << 1U) ^ 0x31U);
            } else {
                crc <<= 1U;
            }
        }
    }

    return crc;
}

}  // namespace

CanTransport::CanTransport(const std::string& device_path, uint8_t channel, uint32_t tx_id, uint32_t rx_id, int32_t read_timeout_us)
    : device_handle_(-1)
    , device_path_(device_path)
    , channel_(channel)
    , tx_id_(tx_id)
    , rx_id_(rx_id)
    , read_timeout_us_(read_timeout_us)
    , connected_(false)
    , rx_state_(RxState::WaitHeader)
    , rx_length_(0U)
    , rx_expected_len_(0U)
    , rx_crc_(0U)
    , last_rx_byte_tp_(std::chrono::steady_clock::now())
{
}

CanTransport::~CanTransport()
{
    disconnect();
}

bool CanTransport::connect()
{
    if (connected_) {
        return true;
    }

    device_handle_ = openUSBCAN(device_path_.c_str());
    if (device_handle_ < 0) {
        setLastError("openUSBCAN() failed for " + device_path_);
        return false;
    }

    resetRxState();
    connected_ = true;
    return true;
}

void CanTransport::disconnect()
{
    if (device_handle_ >= 0) {
        (void)closeUSBCAN(device_handle_);
        device_handle_ = -1;
    }

    connected_ = false;
    resetRxState();

    std::lock_guard<std::mutex> lock(rx_mutex_);
    rx_frames_.clear();
}

bool CanTransport::isConnected() const
{
    return connected_;
}

bool CanTransport::write(const uint8_t* data, size_t size)
{
    if (!connected_ || device_handle_ < 0) {
        setLastError("SOULDE USB2CAN transport is not connected");
        return false;
    }
    if ((data == nullptr) || (size == 0U) || (size > kMaxFrameBytes) || (size > 0xffU)) {
        setLastError("Invalid payload size for CAN transport");
        return false;
    }

    std::array<uint8_t, kMaxFrameBytes + 4U> packet {};
    packet[0] = kHeader;
    packet[1] = static_cast<uint8_t>(size);
    std::memcpy(packet.data() + 2, data, size);
    packet[2 + size] = crc8_compute(data, size);
    packet[3 + size] = kTail;

    const size_t total_len = size + 4U;
    for (size_t offset = 0; offset < total_len; offset += 8U) {
        FrameInfo info {};
        uint8_t frame_data[8] = {0};
        const uint8_t chunk_len = static_cast<uint8_t>(std::min<size_t>(8U, total_len - offset));

        info.canID = tx_id_;
        info.frameType = STANDARD;
        info.dataLength = chunk_len;
        std::memcpy(frame_data, packet.data() + offset, chunk_len);

        const int32_t written = sendUSBCAN(device_handle_, channel_, &info, frame_data);
        if (written < 0) {
            setLastError("sendUSBCAN() failed");
            return false;
        }
    }

    return true;
}

size_t CanTransport::read(uint8_t* buffer, size_t max_size)
{
    if (!connected_ || device_handle_ < 0) {
        return 0U;
    }
    if ((buffer == nullptr) || (max_size == 0U)) {
        return 0U;
    }

    (void)pumpSocket();

    std::lock_guard<std::mutex> lock(rx_mutex_);
    if (rx_frames_.empty()) {
        return 0U;
    }

    const std::vector<uint8_t>& frame = rx_frames_.front();
    if (frame.size() > max_size) {
        setLastError("Read buffer too small for assembled CAN payload");
        return 0U;
    }

    std::memcpy(buffer, frame.data(), frame.size());
    const size_t frame_size = frame.size();
    rx_frames_.pop_front();
    return frame_size;
}

void CanTransport::setReadCallback(std::function<void(const uint8_t*, size_t)> callback)
{
    read_callback_ = std::move(callback);
}

std::string CanTransport::getDevicePath() const
{
    return device_path_;
}

uint8_t CanTransport::getChannel() const
{
    return channel_;
}

uint32_t CanTransport::getTxId() const
{
    return tx_id_;
}

uint32_t CanTransport::getRxId() const
{
    return rx_id_;
}

int32_t CanTransport::getReadTimeoutUs() const
{
    return read_timeout_us_;
}

std::string CanTransport::getLastError() const
{
    std::lock_guard<std::mutex> lock(error_mutex_);
    return last_error_;
}

bool CanTransport::pumpSocket()
{
    bool received_any = false;

    while (connected_ && device_handle_ >= 0) {
        uint8_t read_channel = 0U;
        FrameInfo info {};
        uint8_t frame_data[8] = {0};
        const int32_t received = readUSBCAN(device_handle_, &read_channel, &info, frame_data, read_timeout_us_);

        if (received < 0) {
            break;
        }
        if ((read_channel != channel_) || (info.canID != rx_id_) || (info.dataLength == 0U)) {
            continue;
        }

        received_any = true;
        processCanPayload(frame_data, info.dataLength);
    }

    return received_any;
}

void CanTransport::processCanPayload(const uint8_t* data, size_t size)
{
    const auto now = std::chrono::steady_clock::now();
    if ((rx_state_ != RxState::WaitHeader) && ((now - last_rx_byte_tp_) > kRxTimeout)) {
        resetRxState();
    }

    for (size_t index = 0; index < size; ++index) {
        processByte(data[index]);
        last_rx_byte_tp_ = now;
    }
}

void CanTransport::processByte(uint8_t byte)
{
    switch (rx_state_) {
    case RxState::WaitHeader:
        if (byte == kHeader) {
            rx_state_ = RxState::WaitLength;
        }
        break;

    case RxState::WaitLength:
        if ((byte == 0U) || (byte > kMaxFrameBytes)) {
            restartOnHeader(byte);
            break;
        }
        rx_expected_len_ = byte;
        rx_length_ = 0U;
        rx_state_ = RxState::WaitPayload;
        break;

    case RxState::WaitPayload:
        rx_payload_[rx_length_++] = byte;
        if (rx_length_ >= rx_expected_len_) {
            rx_state_ = RxState::WaitCrc;
        }
        break;

    case RxState::WaitCrc:
        rx_crc_ = byte;
        rx_state_ = RxState::WaitTail;
        break;

    case RxState::WaitTail:
        if ((byte == kTail) && (rx_crc_ == crc8_compute(rx_payload_.data(), rx_expected_len_))) {
            acceptFrame();
        }
        restartOnHeader(byte);
        break;
    }
}

void CanTransport::resetRxState()
{
    rx_state_ = RxState::WaitHeader;
    rx_length_ = 0U;
    rx_expected_len_ = 0U;
    rx_crc_ = 0U;
    last_rx_byte_tp_ = std::chrono::steady_clock::now();
}

void CanTransport::restartOnHeader(uint8_t byte)
{
    resetRxState();
    if (byte == kHeader) {
        rx_state_ = RxState::WaitLength;
    }
}

void CanTransport::acceptFrame()
{
    std::vector<uint8_t> frame(rx_payload_.begin(), rx_payload_.begin() + rx_expected_len_);
    {
        std::lock_guard<std::mutex> lock(rx_mutex_);
        rx_frames_.push_back(frame);
    }

    if (read_callback_) {
        read_callback_(frame.data(), frame.size());
    }
}

void CanTransport::setLastError(const std::string& error)
{
    std::lock_guard<std::mutex> lock(error_mutex_);
    last_error_ = error;
}

}  // namespace mcu_comm
