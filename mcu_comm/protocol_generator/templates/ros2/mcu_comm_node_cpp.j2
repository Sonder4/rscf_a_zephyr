uint8_t ExtractControlPlaneBits(const uint8_t *bytes, uint16_t bit_offset, uint8_t bit_width)
{
    uint8_t value = 0;

    for (uint8_t index = 0; index < bit_width; ++index) {
        const uint16_t absolute_bit = static_cast<uint16_t>(bit_offset + index);
        const uint8_t byte_index = static_cast<uint8_t>(absolute_bit / 8U);
        const uint8_t inner_bit = static_cast<uint8_t>(absolute_bit % 8U);
        const uint8_t bit_value = static_cast<uint8_t>((bytes[byte_index] >> inner_bit) & 0x01U);
        value = static_cast<uint8_t>(value | static_cast<uint8_t>(bit_value << index));
    }

    return value;
}

void InsertControlPlaneBits(uint8_t *bytes, uint16_t bit_offset, uint8_t bit_width, uint8_t value)
{
    for (uint8_t index = 0; index < bit_width; ++index) {
        const uint16_t absolute_bit = static_cast<uint16_t>(bit_offset + index);
        const uint8_t byte_index = static_cast<uint8_t>(absolute_bit / 8U);
        const uint8_t inner_bit = static_cast<uint8_t>(absolute_bit % 8U);
        const uint8_t mask = static_cast<uint8_t>(0x01U << inner_bit);
        if (((value >> index) & 0x01U) != 0U) {
            bytes[byte_index] = static_cast<uint8_t>(bytes[byte_index] | mask);
        } else {
            bytes[byte_index] = static_cast<uint8_t>(bytes[byte_index] & static_cast<uint8_t>(~mask));
        }
    }
}

