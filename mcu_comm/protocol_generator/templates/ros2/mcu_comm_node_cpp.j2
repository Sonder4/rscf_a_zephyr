{
    return (action_state == msg::SystemStatus::ACTION_STATE_SUCCEEDED) ||
           (action_state == msg::SystemStatus::ACTION_STATE_CANCELED) ||
           (action_state == msg::SystemStatus::ACTION_STATE_ABORTED) ||
           (action_state == msg::SystemStatus::ACTION_STATE_REJECTED);
}

