void McuCommNode::initializeTimers()
{
    // 状态发布定时器
    status_timer_ = this->create_wall_timer(
        std::chrono::duration<double>(1.0 / status_publish_rate_),
        [this]() { this->onStatusTimer(); });

    if (isPacketEnabledForCurrentDevice(PacketID::CHASSIS_CTRL)) {
        cmd_send_timer_ = this->create_wall_timer(
            std::chrono::duration<double>(1.0 / cmd_send_rate_),
            [this]() { this->onCommandSendTimer(); });
    }

    // 重连定时器（初始时未启动）
    if (auto_reconnect_ && !connected_.load()) {
        startReconnectTimer();
    }
}

void McuCommNode::onConnectionStatusChanged(bool connected)
{
    std::lock_guard<std::mutex> lock(mutex_);
    
    bool was_connected = connected_.exchange(connected);

    if (shutting_down_) {
        return;
    }
    
    if (connected && !was_connected) {
        RCLCPP_INFO(this->get_logger(), "Connected to MCU");
        should_reconnect_ = false;
        stopReconnectTimer();
    } else if (!connected && was_connected) {
        RCLCPP_WARN(this->get_logger(), "Disconnected from MCU");
        if (auto_reconnect_) {
            should_reconnect_ = true;
            startReconnectTimer();
        }
    }
}

