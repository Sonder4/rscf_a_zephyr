void McuCommNode::on{{ packet.name | to_pascal_case }}(const {{ packet.name | to_upper_snake }}_t& data)
{
#if MCU_COMM_DEBUG_TRACE
    g_rx_count_{{ packet.name | to_snake_case }}++;
#endif
    if (debug_enabled_) {
        RCLCPP_INFO(this->get_logger(),
                    "[DEBUG] RX pid={{ packet.pid }} {{ packet.name | to_upper_snake }} count=%u",
                    g_rx_count_{{ packet.name | to_snake_case }});
    }

{% if packet.name == 'CHASSIS_FEEDBACK' %}
    nav_msgs::msg::Odometry ros_msg;
    ros_msg.header.stamp = this->now();
    ros_msg.header.frame_id = odom_frame_id_;
    ros_msg.child_frame_id = child_frame_id_;
    ros_msg.twist.twist.linear.x = data.vx_mps;
    ros_msg.twist.twist.linear.y = data.vy_mps;
    ros_msg.pose.pose.position.x = data.odom_x_mm / 1000.0;
    ros_msg.pose.pose.position.y = data.odom_y_mm / 1000.0;

    if ({{ packet.name | to_snake_case }}_publisher_) {
        {{ packet.name | to_snake_case }}_publisher_->publish(ros_msg);
    }
    invoke{{ packet.name | to_upper_snake }}Callbacks(ros_msg);
{% elif packet.name == 'IMU_EULER' %}
    sensor_msgs::msg::Imu ros_msg;
    ros_msg.header.stamp = this->now();
    ros_msg.header.frame_id = imu_frame_id_;

    constexpr double kDegToRad = 3.14159265358979323846 / 180.0;
    const double roll_rad = static_cast<double>(data.roll) * kDegToRad;
    const double pitch_rad = static_cast<double>(data.pitch) * kDegToRad;
    const double yaw_rad = static_cast<double>(data.yaw) * kDegToRad;

    const double half_roll = roll_rad * 0.5;
    const double half_pitch = pitch_rad * 0.5;
    const double half_yaw = yaw_rad * 0.5;

    const double cr = std::cos(half_roll);
    const double sr = std::sin(half_roll);
    const double cp = std::cos(half_pitch);
    const double sp = std::sin(half_pitch);
    const double cy = std::cos(half_yaw);
    const double sy = std::sin(half_yaw);

    ros_msg.orientation.w = cr * cp * cy + sr * sp * sy;
    ros_msg.orientation.x = sr * cp * cy - cr * sp * sy;
    ros_msg.orientation.y = cr * sp * cy + sr * cp * sy;
    ros_msg.orientation.z = cr * cp * sy - sr * sp * cy;

    if ({{ packet.name | to_snake_case }}_publisher_) {
        {{ packet.name | to_snake_case }}_publisher_->publish(ros_msg);
    }
    invoke{{ packet.name | to_upper_snake }}Callbacks(ros_msg);
{% elif packet.name == 'SYSTEM_STATUS' %}
    msg::SystemStatus ros_msg;
    for (size_t index = 0; index < ros_msg.{{ system_status_packet.control_plane_bytes_field_name }}.size(); ++index) {
        ros_msg.{{ system_status_packet.control_plane_bytes_field_name }}[index] = data.{{ system_status_packet.control_plane_bytes_field_name }}[index];
    }
{% for field in system_status_packet.control_plane_fields %}
    ros_msg.{{ field.name }} = ExtractControlPlaneBits(
        data.{{ system_status_packet.control_plane_bytes_field_name }},
        SYSTEM_STATUS_{{ field.name | to_upper_snake }}_OFFSET,
        SYSTEM_STATUS_{{ field.name | to_upper_snake }}_WIDTH);
{% endfor %}

    {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        latest_system_status_ = ros_msg;
        latest_system_status_valid_ = true;

        if (pending_service_active_
            && (ros_msg.service_id == pending_service_id_)
            && (ros_msg.service_ticket == pending_service_ticket_)
            && (ros_msg.service_result != msg::SystemStatus::SERVICE_RESULT_NONE)) {
            pending_service_result_ = ros_msg.service_result;
            pending_service_done_ = true;
            pending_service_active_ = false;
            control_plane_cv_.notify_all();
            if (debug_enabled_) {
                RCLCPP_INFO(this->get_logger(),
                            "[DEBUG] service update id=%u ticket=%u result=%u",
                            ros_msg.service_id,
                            ros_msg.service_ticket,
                            ros_msg.service_result);
            }
        }

        if (action_active_
            && (ros_msg.action_id == active_action_id_)
            && (ros_msg.action_ticket == active_action_ticket_)) {
            if (ros_msg.action_state >= msg::SystemStatus::ACTION_STATE_ACCEPTED) {
                active_action_acknowledged_ = true;
                control_plane_cv_.notify_all();
            }
            active_action_state_ = ros_msg.action_state;
            active_action_result_ = ros_msg.action_result;
            active_action_progress_ = ros_msg.action_progress;
            if (debug_enabled_) {
                RCLCPP_INFO(this->get_logger(),
                            "[DEBUG] action state update id=%u ticket=%u state=%u result=%u progress=%u",
                            ros_msg.action_id,
                            ros_msg.action_ticket,
                            ros_msg.action_state,
                            ros_msg.action_result,
                            ros_msg.action_progress);
            }
            publishActiveActionFeedback();
            if (IsTerminalActionState(active_action_state_)) {
                finalizeActiveAction();
            }
        }
    }

    if ({{ packet.name | to_snake_case }}_publisher_) {
        {{ packet.name | to_snake_case }}_publisher_->publish(ros_msg);
    }
    invoke{{ packet.name | to_upper_snake }}Callbacks(ros_msg);
{% else %}
    msg::{{ packet.name | to_pascal_case }} ros_msg;
{% for field in packet.data_fields %}
    ros_msg.{{ field.name }} = data.{{ field.name }};
{% endfor %}

    if ({{ packet.name | to_snake_case }}_publisher_) {
        {{ packet.name | to_snake_case }}_publisher_->publish(ros_msg);
    }
    invoke{{ packet.name | to_upper_snake }}Callbacks(ros_msg);
{% endif %}
}

