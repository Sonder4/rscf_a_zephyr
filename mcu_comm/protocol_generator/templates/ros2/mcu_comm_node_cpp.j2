void McuCommNode::onVelocityCommand(const geometry_msgs::msg::Twist::SharedPtr msg)
{
    if (!isPacketEnabledForCurrentDevice(PacketID::CHASSIS_CTRL) || (msg == nullptr)) {
        return;
    }

    std::lock_guard<std::mutex> lock(cmd_vel_mutex_);
    latest_cmd_vel_ = *msg;
    latest_cmd_vel_valid_ = true;
}

void McuCommNode::onHeadingTarget(const std_msgs::msg::Float32::SharedPtr msg)
{
    if (!isPacketEnabledForCurrentDevice(PacketID::CHASSIS_CTRL) || (msg == nullptr)) {
        return;
    }

    std::lock_guard<std::mutex> lock(cmd_vel_mutex_);
    latest_heading_target_deg_ = msg->data;
}

void McuCommNode::onCommandSendTimer()
{
    geometry_msgs::msg::Twist cmd_msg;
    float heading_target_deg = 0.0f;
    std::vector<uint8_t> frame_data;

    if (!isPacketEnabledForCurrentDevice(PacketID::CHASSIS_CTRL)) {
        return;
    }

    {
        std::lock_guard<std::mutex> lock(cmd_vel_mutex_);
        if (!latest_cmd_vel_valid_) {
            return;
        }
        cmd_msg = latest_cmd_vel_;
        heading_target_deg = latest_heading_target_deg_;
    }

    if (!comm_manager_ || !comm_manager_->isConnected()) {
        return;
    }

    if (buildVelocityCommandFrame(cmd_msg.linear.x, cmd_msg.linear.y, cmd_msg.angular.z,
                                  heading_target_deg, frame_data)) {
        (void)comm_manager_->sendFrame(PacketID::CHASSIS_CTRL, static_cast<DeviceID>(device_mid_), frame_data);
    }
}

void McuCommNode::onStatusTimer()
{
    std_msgs::msg::Header status_msg;
    status_msg.stamp = this->now();
    status_msg.frame_id = connected_ ? "connected" : "disconnected";

    status_publisher_->publish(status_msg);
}

void McuCommNode::onReconnectTimer()
{
    if (!should_reconnect_ || connected_) {
        return;
    }

    RCLCPP_INFO(this->get_logger(), "Attempting to reconnect...");
    attemptReconnect();
}

void McuCommNode::attemptReconnect()
{
    if (comm_manager_) {
        comm_manager_->stop();
        
        // 重新初始化并启动
        if (comm_manager_->initialize() && comm_manager_->start()) {
            RCLCPP_INFO(this->get_logger(), "Reconnect transport restarted, waiting for MCU data");
        } else {
            RCLCPP_WARN(this->get_logger(), "Reconnection failed, will retry in %d ms", reconnect_interval_ms_);
        }
    }
}

void McuCommNode::startReconnectTimer()
{
    if (!reconnect_timer_) {
        reconnect_timer_ = this->create_wall_timer(
            std::chrono::milliseconds(reconnect_interval_ms_),
            [this]() { this->onReconnectTimer(); });
    }
}

void McuCommNode::stopReconnectTimer()
{
    if (reconnect_timer_) {
        reconnect_timer_->cancel();
        reconnect_timer_.reset();
    }
}

// 大端序数据解析辅助函数
float McuCommNode::beToFloat(const std::vector<uint8_t>& data, size_t offset)
{
    if (offset + 3 >= data.size()) {
        return 0.0f;
    }
    uint32_t beValue = (static_cast<uint32_t>(data[offset]) << 24) |
                      (static_cast<uint32_t>(data[offset + 1]) << 16) |
                      (static_cast<uint32_t>(data[offset + 2]) << 8) |
                      static_cast<uint32_t>(data[offset + 3]);
    float result;
    std::memcpy(&result, &beValue, sizeof(float));
    return result;
}

int16_t McuCommNode::beToInt16(const std::vector<uint8_t>& data, size_t offset)
{
    if (offset + 1 >= data.size()) {
        return 0;
    }
    uint16_t beValue = (static_cast<uint16_t>(data[offset]) << 8) |
                       static_cast<uint16_t>(data[offset + 1]);
    return static_cast<int16_t>(beValue);
}

uint16_t McuCommNode::beToUint16(const std::vector<uint8_t>& data, size_t offset)
{
    if (offset + 1 >= data.size()) {
        return 0;
    }
    return (static_cast<uint16_t>(data[offset]) << 8) |
           static_cast<uint16_t>(data[offset + 1]);
}

int32_t McuCommNode::beToInt32(const std::vector<uint8_t>& data, size_t offset)
{
    if (offset + 3 >= data.size()) {
        return 0;
    }
    uint32_t beValue = (static_cast<uint32_t>(data[offset]) << 24) |
                      (static_cast<uint32_t>(data[offset + 1]) << 16) |
                      (static_cast<uint32_t>(data[offset + 2]) << 8) |
                      static_cast<uint32_t>(data[offset + 3]);
    return static_cast<int32_t>(beValue);
}

uint32_t McuCommNode::beToUint32(const std::vector<uint8_t>& data, size_t offset)
{
    if (offset + 3 >= data.size()) {
        return 0;
    }
    return (static_cast<uint32_t>(data[offset]) << 24) |
           (static_cast<uint32_t>(data[offset + 1]) << 16) |
           (static_cast<uint32_t>(data[offset + 2]) << 8) |
           static_cast<uint32_t>(data[offset + 3]);
}

void McuCommNode::parseImuData(const std::vector<uint8_t>& data, sensor_msgs::msg::Imu& imu_msg)
{
    // 解析IMU欧拉角数据（大端序）
    // 根据PL值计算有效数据长度，STM32基准：PL = 数据域长度（PID + LEN + DATA）
    if (data.size() < 4) {
        RCLCPP_WARN(this->get_logger(), "Invalid IMU data size: %zu", data.size());
        return;
    }
    
    // 从数据中提取PL值（第2个字节）
    uint8_t pl = data[1];
    
    // 计算数据域起始偏移（SOF + PL = 2字节）
    size_t data_offset = 2;
    
    // 计算有效数据长度
    size_t payload_len = pl;
    
    // 检查数据是否足够（至少包含PID + LEN + 12字节IMU数据）
    if (data.size() < data_offset + payload_len || payload_len < 14) {
        RCLCPP_WARN(this->get_logger(), "Invalid IMU payload length: PL=%d, data_size=%zu", pl, data.size());
        return;
    }
    
    // 计算实际数据起始位置（跳过PID和LEN）
    size_t field_offset = data_offset + 2;

    // 解析roll, pitch, yaw（大端序float，各4字节）
    float roll = beToFloat(data, field_offset);
    float pitch = beToFloat(data, field_offset + 4);
    float yaw = beToFloat(data, field_offset + 8);

    if (debug_enabled_) {
        RCLCPP_INFO(this->get_logger(), "IMU: roll=%.3f, pitch=%.3f, yaw=%.3f", roll, pitch, yaw);
    }

    // 设置消息头
    imu_msg.header.stamp = this->now();
    imu_msg.header.frame_id = imu_frame_id_;

    // 欧拉角转四元数（ZYX顺序）
    double cy = cos(yaw * 0.5);
    double sy = sin(yaw * 0.5);
    double cp = cos(pitch * 0.5);
    double sp = sin(pitch * 0.5);
    double cr = cos(roll * 0.5);
    double sr = sin(roll * 0.5);

    imu_msg.orientation.w = cr * cp * cy + sr * sp * sy;
    imu_msg.orientation.x = sr * cp * cy - cr * sp * sy;
    imu_msg.orientation.y = cr * sp * cy + sr * cp * sy;
    imu_msg.orientation.z = cr * cp * sy - sr * sp * cy;

    // 设置协方差矩阵
    for (int i = 0; i < 9; i++) {
        imu_msg.orientation_covariance[i] = 0.0;
        imu_msg.angular_velocity_covariance[i] = 0.0;
        imu_msg.linear_acceleration_covariance[i] = 0.0;
    }
    imu_msg.orientation_covariance[0] = 0.01;
    imu_msg.orientation_covariance[4] = 0.01;
    imu_msg.orientation_covariance[8] = 0.01;

    // 没有角速度和线加速度数据，设置为NaN
    imu_msg.angular_velocity.x = NAN;
    imu_msg.angular_velocity.y = NAN;
    imu_msg.angular_velocity.z = NAN;
    imu_msg.linear_acceleration.x = NAN;
    imu_msg.linear_acceleration.y = NAN;
    imu_msg.linear_acceleration.z = NAN;
}

void McuCommNode::parseOdometryData(const std::vector<uint8_t>& data, nav_msgs::msg::Odometry& odom_msg)
{
    // 解析底盘反馈数据（大端序）
    // 根据PL值计算有效数据长度，STM32基准：PL = 数据域长度（PID + LEN + DATA）
    if (data.size() < 4) {
        RCLCPP_WARN(this->get_logger(), "Invalid odometry data size: %zu", data.size());
        return;
    }
    
    // 从数据中提取PL值（第2个字节）
    uint8_t pl = data[1];
    
    // 计算数据域起始偏移（SOF + PL = 2字节）
    size_t data_offset = 2;
    
    // 计算有效数据长度
    size_t payload_len = pl;
    
    // 检查数据是否足够（至少包含PID + LEN + 16字节里程计数据）
    if (data.size() < data_offset + payload_len || payload_len < 18) {
        RCLCPP_WARN(this->get_logger(), "Invalid odometry payload length: PL=%d, data_size=%zu", pl, data.size());
        return;
    }
    
    // 计算实际数据起始位置（跳过PID和LEN）
    size_t field_offset = data_offset + 2;

    // 解析vx, vy, odom_x, odom_y（大端序float，各4字节）
    float vx = beToFloat(data, field_offset);
    float vy = beToFloat(data, field_offset + 4);
    float odom_x = beToFloat(data, field_offset + 8);
    float odom_y = beToFloat(data, field_offset + 12);

    if (debug_enabled_) {
        RCLCPP_INFO(this->get_logger(), "Odometry: vx=%.3f, vy=%.3f, x=%.3f, y=%.3f", vx, vy, odom_x, odom_y);
    }

    // 设置消息头
    odom_msg.header.stamp = this->now();
    odom_msg.header.frame_id = odom_frame_id_;
    odom_msg.child_frame_id = child_frame_id_;

    // 设置位置（单位从mm转换为m）
    odom_msg.pose.pose.position.x = odom_x / 1000.0;
    odom_msg.pose.pose.position.y = odom_y / 1000.0;
    odom_msg.pose.pose.position.z = 0.0;

    // 设置方向（暂时设为单位四元数）
    odom_msg.pose.pose.orientation.x = 0.0;
    odom_msg.pose.pose.orientation.y = 0.0;
    odom_msg.pose.pose.orientation.z = 0.0;
    odom_msg.pose.pose.orientation.w = 1.0;

    // 设置速度
    odom_msg.twist.twist.linear.x = vx;
    odom_msg.twist.twist.linear.y = vy;
    odom_msg.twist.twist.linear.z = 0.0;
    odom_msg.twist.twist.angular.x = 0.0;
    odom_msg.twist.twist.angular.y = 0.0;
    odom_msg.twist.twist.angular.z = 0.0;

    // 设置协方差矩阵
    for (int i = 0; i < 36; i++) {
        odom_msg.pose.covariance[i] = 0.0;
        odom_msg.twist.covariance[i] = 0.0;
    }
    odom_msg.pose.covariance[0] = 0.01;
    odom_msg.pose.covariance[7] = 0.01;
    odom_msg.pose.covariance[35] = 0.01;
    odom_msg.twist.covariance[0] = 0.01;
    odom_msg.twist.covariance[7] = 0.01;
}

bool McuCommNode::buildVelocityCommandFrame(float linear_x, float linear_y, float angular_z,
                                            float heading_target_deg,
                                            std::vector<uint8_t>& frame_data)
{
    float speed_mps = std::sqrt(linear_x * linear_x + linear_y * linear_y);
    float direction_deg = std::atan2(linear_y, linear_x) * 180.0f / static_cast<float>(M_PI);
    float yaw_rate_radps = angular_z;
    float heading_deg = heading_target_deg;
    int16_t heading_cdeg = 0;

    const float LIMIT_V = 10.0f;
    const float LIMIT_W = 10.0f;

    speed_mps = std::min(std::max(speed_mps, -LIMIT_V), LIMIT_V);
    direction_deg = std::min(std::max(direction_deg, -180.0f), 180.0f);
    yaw_rate_radps = std::min(std::max(yaw_rate_radps, -LIMIT_W), LIMIT_W);
    heading_deg = std::min(std::max(heading_deg, -180.0f), 180.0f);

    const auto to_fixed_1000 = [](float val) -> int16_t {
        return static_cast<int16_t>(std::lround(val * 1000.0f));
    };
    const auto to_fixed_100 = [](float val) -> int16_t {
        return static_cast<int16_t>(std::lround(val * 100.0f));
    };

    heading_cdeg = to_fixed_100(heading_deg);

    frame_data.resize(8U);

    auto push_int16 = [&](int16_t val, int offset) {
        std::memcpy(&frame_data[static_cast<size_t>(offset)], &val, sizeof(int16_t));
    };

    push_int16(to_fixed_1000(speed_mps), 0);
    push_int16(to_fixed_100(direction_deg), 2);
    push_int16(to_fixed_1000(yaw_rate_radps), 4);
    push_int16(heading_cdeg, 6);

    if (debug_enabled_) {
        RCLCPP_INFO(this->get_logger(),
            "Chassis CMD: speed=%.3f m/s dir=%.2f deg yaw_rate=%.3f rad/s heading_deg=%.2f heading_cdeg=%d",
            speed_mps, direction_deg, yaw_rate_radps, heading_deg, heading_cdeg);
    }

    return true;
}

bool McuCommNode::buildSystemCmdFrame(const msg::SystemCmd& cmd_msg,
                                      std::vector<uint8_t>& frame_data)
{
{% if system_cmd_packet is not none %}
    SYSTEM_CMD_t data {};
    for (size_t index = 0; index < {{ system_cmd_packet.control_plane_num_bytes }}U; ++index) {
        data.{{ system_cmd_packet.control_plane_bytes_field_name }}[index] = cmd_msg.{{ system_cmd_packet.control_plane_bytes_field_name }}[index];
    }

{% for field in system_cmd_packet.control_plane_fields %}
    InsertControlPlaneBits(
        data.{{ system_cmd_packet.control_plane_bytes_field_name }},
        SYSTEM_CMD_{{ field.name | to_upper_snake }}_OFFSET,
        SYSTEM_CMD_{{ field.name | to_upper_snake }}_WIDTH,
        static_cast<uint8_t>(cmd_msg.{{ field.name }}));
{% endfor %}

    frame_data.resize(sizeof(data));
    std::memcpy(frame_data.data(), &data, sizeof(data));
    return true;
{% else %}
    (void)cmd_msg;
    frame_data.clear();
    return false;
{% endif %}
}

bool McuCommNode::sendSystemCmdFrame(const msg::SystemCmd& cmd_msg)
{
    std::vector<uint8_t> frame_data;

    if (!isPacketEnabledForCurrentDevice(PacketID::SYSTEM_CMD)) {
        return false;
    }
    if (!comm_manager_ || !comm_manager_->isConnected()) {
        return false;
    }
    if (!buildSystemCmdFrame(cmd_msg, frame_data)) {
        return false;
    }

    if (debug_enabled_) {
        g_tx_count_system_cmd++;
        RCLCPP_INFO(this->get_logger(),
                    "[DEBUG] TX pid=0x09 SYSTEM_CMD count=%u",
                    g_tx_count_system_cmd);
    }
    return comm_manager_->sendFrame(PacketID::SYSTEM_CMD, static_cast<DeviceID>(device_mid_), frame_data);
}

bool McuCommNode::sendServiceRequest(uint8_t service_id, uint8_t service_arg, uint8_t service_ticket)
{
    msg::SystemCmd cmd_msg;
    for (size_t index = 0; index < cmd_msg.cmd_bytes.size(); ++index) {
        cmd_msg.cmd_bytes[index] = 0U;
    }
    cmd_msg.service_id = service_id;
    cmd_msg.service_arg = service_arg;
    cmd_msg.service_ticket = service_ticket;
    cmd_msg.action_id = msg::SystemCmd::ACTION_ID_NONE;
    cmd_msg.action_cmd = msg::SystemCmd::ACTION_CMD_QUERY;
    cmd_msg.action_ticket = 0U;
    cmd_msg.action_param = 0U;
    return sendSystemCmdFrame(cmd_msg);
}

bool McuCommNode::waitServiceResponse(uint8_t service_id, uint8_t service_ticket, uint8_t& service_result)
{
    std::unique_lock<std::mutex> lock(control_plane_mutex_);
    const bool finished = control_plane_cv_.wait_for(
        lock,
        std::chrono::milliseconds(timeout_ms_),
        [this, service_id, service_ticket]() {
            return pending_service_done_
                && (pending_service_id_ == service_id)
                && (pending_service_ticket_ == service_ticket);
        });
    if (!finished) {
        return false;
    }
    service_result = pending_service_result_;
    pending_service_done_ = false;
    return true;
}

bool McuCommNode::sendActionCommand(uint8_t action_id, uint8_t action_cmd, uint8_t action_ticket, uint8_t action_param)
{
    msg::SystemCmd cmd_msg;
    for (size_t index = 0; index < cmd_msg.cmd_bytes.size(); ++index) {
        cmd_msg.cmd_bytes[index] = 0U;
    }
    cmd_msg.service_id = msg::SystemCmd::SERVICE_ID_NONE;
    cmd_msg.service_arg = 0U;
    cmd_msg.service_ticket = 0U;
    cmd_msg.action_id = action_id;
    cmd_msg.action_cmd = action_cmd;
    cmd_msg.action_ticket = action_ticket;
    cmd_msg.action_param = action_param;
    return sendSystemCmdFrame(cmd_msg);
}

bool McuCommNode::requestServiceWithRetry(uint8_t service_id, uint8_t service_arg, uint8_t service_ticket, uint8_t& service_result)
{
    uint8_t attempt = 0U;

    /*
     * 使用同一个 ticket 做有限次重发。
     * MCU 侧对重复 ticket 只回显不重复执行，因此这里可以在丢包时安全重试。
     */
    for (attempt = 0U; attempt < kControlPlaneMaxRetryCount_; ++attempt)
    {
        {
            std::lock_guard<std::mutex> lock(control_plane_mutex_);
            pending_service_done_ = false;
            pending_service_result_ = msg::SystemStatus::SERVICE_RESULT_NONE;
        }

        if (!sendServiceRequest(service_id, service_arg, service_ticket))
        {
            continue;
        }

        if (waitServiceResponse(service_id, service_ticket, service_result))
        {
            return true;
        }
    }

    return false;
}

bool McuCommNode::waitActionAck(uint8_t action_id, uint8_t action_ticket)
{
    std::unique_lock<std::mutex> lock(control_plane_mutex_);

    return control_plane_cv_.wait_for(
        lock,
        std::chrono::milliseconds(timeout_ms_),
        [this, action_id, action_ticket]() {
            return action_active_
                && active_action_acknowledged_
                && (active_action_id_ == action_id)
                && (active_action_ticket_ == action_ticket);
        });
}

bool McuCommNode::startActionWithRetry(uint8_t action_id, uint8_t action_ticket, uint8_t action_param)
{
    uint8_t attempt = 0U;

    /*
     * action 启动以 MCU 回写的 ACCEPTED/RUNNING 为 ACK。
     * 若状态包丢失，则使用同一 ticket 重发 START，请求 MCU 回显当前状态。
     */
    for (attempt = 0U; attempt < kControlPlaneMaxRetryCount_; ++attempt)
    {
        {
            std::lock_guard<std::mutex> lock(control_plane_mutex_);
            active_action_acknowledged_ = false;
        }

        if (!sendActionCommand(action_id,
                               msg::SystemCmd::ACTION_CMD_START,
                               action_ticket,
                               action_param))
        {
            continue;
        }

        if (waitActionAck(action_id, action_ticket))
        {
            return true;
        }
    }

    return false;
}

void McuCommNode::resetActiveActionState()
{
    action_active_ = false;
    active_action_acknowledged_ = false;
    active_action_id_ = msg::SystemStatus::ACTION_ID_NONE;
    active_action_ticket_ = 0U;
    active_action_state_ = msg::SystemStatus::ACTION_STATE_IDLE;
    active_action_result_ = msg::SystemStatus::ACTION_RESULT_NONE;
    active_action_progress_ = 0U;
{% for action in control_plane.actions %}
    {{ action.snake_name }}_goal_handle_.reset();
{% endfor %}
}

void McuCommNode::publishActiveActionFeedback()
{
    if (!action_active_) {
        return;
    }
{% for action in control_plane.actions %}
    if ((active_action_id_ == msg::SystemStatus::ACTION_ID_{{ action.enum_entry }})
        && {{ action.snake_name }}_goal_handle_) {
        auto feedback = std::make_shared<action::{{ action.pascal_name }}::Feedback>();
        feedback->action_id = active_action_id_;
        feedback->action_state = active_action_state_;
        feedback->action_ticket = active_action_ticket_;
        feedback->action_result = active_action_result_;
        feedback->task_state = active_action_progress_;
        {{ action.snake_name }}_goal_handle_->publish_feedback(feedback);
        return;
    }
{% endfor %}
}

void McuCommNode::finalizeActiveAction()
{
    if (!action_active_) {
        return;
    }
{% for action in control_plane.actions %}
    if ((active_action_id_ == msg::SystemStatus::ACTION_ID_{{ action.enum_entry }})
        && {{ action.snake_name }}_goal_handle_) {
        auto result = std::make_shared<action::{{ action.pascal_name }}::Result>();
        result->action_id = active_action_id_;
        result->action_state = active_action_state_;
        result->action_ticket = active_action_ticket_;
        result->action_result = active_action_result_;
        result->task_state = active_action_progress_;

        if (active_action_state_ == msg::SystemStatus::ACTION_STATE_SUCCEEDED) {
            {{ action.snake_name }}_goal_handle_->succeed(result);
        } else if (active_action_state_ == msg::SystemStatus::ACTION_STATE_CANCELED) {
            {{ action.snake_name }}_goal_handle_->canceled(result);
        } else {
            {{ action.snake_name }}_goal_handle_->abort(result);
        }
        resetActiveActionState();
        return;
    }
{% endfor %}
    resetActiveActionState();
}

{% for service in control_plane.services %}
void McuCommNode::handle{{ service.pascal_name }}(
    const std::shared_ptr<srv::{{ service.pascal_name }}::Request> request,
    std::shared_ptr<srv::{{ service.pascal_name }}::Response> response)
{
    uint8_t service_result = msg::SystemStatus::SERVICE_RESULT_ERROR;
    uint8_t service_ticket = 0U;

    if ((request == nullptr) || (response == nullptr)) {
        return;
    }

    if (!IsControlPlaneServiceArgInRange(msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }},
                                         request->{{ service.request_field_name }})) {
        response->service_id = msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }};
        response->service_result = msg::SystemStatus::SERVICE_RESULT_REJECT;
        response->service_ticket = 0U;
        return;
    }

    {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        if (pending_service_active_) {
            response->service_id = msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }};
            response->service_result = msg::SystemStatus::SERVICE_RESULT_REJECT;
            response->service_ticket = 0U;
            return;
        }
        service_ticket = next_service_ticket_;
        next_service_ticket_ = static_cast<uint8_t>((next_service_ticket_ + 1U) & 0x03U);
        pending_service_active_ = true;
        pending_service_done_ = false;
        pending_service_id_ = msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }};
        pending_service_ticket_ = service_ticket;
        pending_service_result_ = msg::SystemStatus::SERVICE_RESULT_NONE;
    }

    if (!requestServiceWithRetry(msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }},
                                 request->{{ service.request_field_name }},
                                 service_ticket,
                                 service_result)) {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        pending_service_active_ = false;
        pending_service_done_ = false;
        pending_service_result_ = msg::SystemStatus::SERVICE_RESULT_ERROR;
        response->service_id = msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }};
        response->service_result = msg::SystemStatus::SERVICE_RESULT_ERROR;
        response->service_ticket = service_ticket;
        return;
    }
    {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        pending_service_active_ = false;
    }

    response->service_id = msg::SystemStatus::SERVICE_ID_{{ service.enum_entry }};
    response->service_result = service_result;
    response->service_ticket = service_ticket;
}

{% endfor %}
{% for action in control_plane.actions %}
rclcpp_action::GoalResponse McuCommNode::handle{{ action.pascal_name }}Goal(
    const rclcpp_action::GoalUUID& uuid,
    std::shared_ptr<const action::{{ action.pascal_name }}::Goal> goal)
{
    (void)uuid;
    (void)goal;
    std::lock_guard<std::mutex> lock(control_plane_mutex_);
    if (action_active_) {
        return rclcpp_action::GoalResponse::REJECT;
    }
    if (!comm_manager_ || !comm_manager_->isConnected()) {
        return rclcpp_action::GoalResponse::REJECT;
    }
    return rclcpp_action::GoalResponse::ACCEPT_AND_EXECUTE;
}

rclcpp_action::CancelResponse McuCommNode::handle{{ action.pascal_name }}Cancel(
    const std::shared_ptr<{{ action.pascal_name }}GoalHandle> goal_handle)
{
    std::lock_guard<std::mutex> lock(control_plane_mutex_);
    if (!action_active_ || ({{ action.snake_name }}_goal_handle_ != goal_handle)) {
        return rclcpp_action::CancelResponse::REJECT;
    }
    if (!sendActionCommand(msg::SystemStatus::ACTION_ID_{{ action.enum_entry }},
                           msg::SystemCmd::ACTION_CMD_CANCEL,
                           active_action_ticket_,
                           0U)) {
        return rclcpp_action::CancelResponse::REJECT;
    }
    return rclcpp_action::CancelResponse::ACCEPT;
}

void McuCommNode::handle{{ action.pascal_name }}Accepted(
    const std::shared_ptr<{{ action.pascal_name }}GoalHandle> goal_handle)
{
    uint8_t action_ticket = 0U;
    uint8_t action_param = 0U;

    if (goal_handle == nullptr) {
        return;
    }
    action_param = goal_handle->get_goal()->{{ action.goal_field_name }};

    {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        if (action_active_) {
            auto result = std::make_shared<action::{{ action.pascal_name }}::Result>();
            result->action_id = msg::SystemStatus::ACTION_ID_{{ action.enum_entry }};
            result->action_state = msg::SystemStatus::ACTION_STATE_REJECTED;
            result->action_ticket = 0U;
            result->action_result = msg::SystemStatus::ACTION_RESULT_FAIL;
            result->task_state = 0U;
            goal_handle->abort(result);
            return;
        }

        action_ticket = next_action_ticket_;
        next_action_ticket_ = static_cast<uint8_t>((next_action_ticket_ + 1U) & 0x03U);
        action_active_ = true;
        active_action_acknowledged_ = false;
        active_action_id_ = msg::SystemStatus::ACTION_ID_{{ action.enum_entry }};
        active_action_ticket_ = action_ticket;
        active_action_state_ = msg::SystemStatus::ACTION_STATE_IDLE;
        active_action_result_ = msg::SystemStatus::ACTION_RESULT_NONE;
        active_action_progress_ = 0U;
        {{ action.snake_name }}_goal_handle_ = goal_handle;
    }

    if (!startActionWithRetry(msg::SystemStatus::ACTION_ID_{{ action.enum_entry }},
                              action_ticket,
                              action_param)) {
        std::lock_guard<std::mutex> lock(control_plane_mutex_);
        auto result = std::make_shared<action::{{ action.pascal_name }}::Result>();
        result->action_id = msg::SystemStatus::ACTION_ID_{{ action.enum_entry }};
        result->action_state = msg::SystemStatus::ACTION_STATE_ABORTED;
        result->action_ticket = action_ticket;
        result->action_result = msg::SystemStatus::ACTION_RESULT_FAIL;
        result->task_state = 0U;
        goal_handle->abort(result);
        resetActiveActionState();
        return;
    }
}

