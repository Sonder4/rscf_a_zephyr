void McuCommNode::initializeCommunication()
{
    // 创建协议解析器
    parser_ = std::make_shared<ProtocolParser>();
    const auto build_transport = [this](TransportType transport_type) -> std::shared_ptr<ITransport> {
        if (transport_type == TransportType::Can) {
            return std::make_shared<CanTransport>(
                can_device_path_,
                static_cast<uint8_t>(can_channel_),
                static_cast<uint32_t>(can_tx_id_),
                static_cast<uint32_t>(can_rx_id_),
                can_read_timeout_us_);
        }
        if (transport_type == TransportType::Tcp) {
            return std::make_shared<TcpTransport>(tcp_host_, tcp_port_, tcp_timeout_ms_, tcp_no_delay_);
        }
        return std::make_shared<SerialTransport>(port_name_, baud_rate_);
    };

    const auto configure_comm_manager = [this](const std::shared_ptr<ITransport>& transport) -> bool {
        transport_ = transport;
        comm_manager_ = std::make_shared<CommManager>(transport_, parser_);
        comm_manager_->registerConnectionCallback(
            [this](bool connected) { this->onConnectionStatusChanged(connected); });

    // 注册数据包回调（小端序，直接按结构体拷贝）
{% for packet in packets %}
{% if packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional' %}
    if (isPacketEnabledForCurrentDevice(PacketID::{{ packet.name | to_upper_snake }})) {
    comm_manager_->registerCallback(
        PacketID::{{ packet.name | to_upper_snake }},
        [this](const std::vector<uint8_t>& data) {
            if (data.size() < sizeof({{ packet.name | to_upper_snake }}_t)) {
                RCLCPP_WARN(this->get_logger(),
                            "{{ packet.name | to_upper_snake }} payload too short: %zu < %zu",
                            data.size(),
                            sizeof({{ packet.name | to_upper_snake }}_t));
                return;
            }
            {{ packet.name | to_upper_snake }}_t parsed_data{};
            std::memcpy(&parsed_data, data.data(), sizeof({{ packet.name | to_upper_snake }}_t));
            this->on{{ packet.name | to_pascal_case }}(parsed_data);
        });
    }
{% endif %}
{% endfor %}

        return comm_manager_->initialize() && comm_manager_->start();
    };

    const TransportType requested_transport = ParseTransportType(transport_type_);
    const TransportType fallback_transport = ParseTransportType(fallback_transport_type_);

    bool started = configure_comm_manager(build_transport(requested_transport));
    if (!started && (fallback_transport != requested_transport)) {
        started = configure_comm_manager(build_transport(fallback_transport));
        if (started) {
            transport_type_ = TransportTypeToString(fallback_transport);
        }
    }

    should_reconnect_ = auto_reconnect_ && !connected_.load();
}

