#include <arpa/inet.h>
#include <netinet/in.h>
#include <sys/socket.h>
#include <unistd.h>

#include <cerrno>
#include <csignal>
#include <cstring>
#include <iomanip>
#include <iostream>
#include <sstream>
#include <string>
#include <vector>

#include "protocol/protocol_parser.hpp"

namespace {

volatile std::sig_atomic_t g_running = 1;

void handleSignal(int) {
    g_running = 0;
}

int16_t readInt16Le(const std::vector<uint8_t>& data, std::size_t offset) {
    if (offset + 1 >= data.size()) {
        return 0;
    }
    uint16_t value = static_cast<uint16_t>(data[offset]) |
                     (static_cast<uint16_t>(data[offset + 1]) << 8);
    return static_cast<int16_t>(value);
}

std::string bytesToHex(const std::vector<uint8_t>& data) {
    std::ostringstream oss;
    oss << std::hex << std::uppercase << std::setfill('0');
    for (std::size_t i = 0; i < data.size(); ++i) {
        if (i > 0) {
            oss << ' ';
        }
        oss << std::setw(2) << static_cast<int>(data[i]);
    }
    return oss.str();
}

}  // namespace

int main(int argc, char** argv) {
    int port = 1387;
    if (argc >= 2) {
        port = std::stoi(argv[1]);
    }

    std::signal(SIGINT, handleSignal);
    std::signal(SIGTERM, handleSignal);

    int sock = ::socket(AF_INET6, SOCK_DGRAM, 0);
    if (sock < 0) {
        std::cerr << "Failed to create IPv6 UDP socket: " << std::strerror(errno) << std::endl;
        return 1;
    }

    int dualStack = 0;
    if (::setsockopt(sock, IPPROTO_IPV6, IPV6_V6ONLY, &dualStack, sizeof(dualStack)) < 0) {
        std::cerr << "Failed to enable dual-stack UDP socket: " << std::strerror(errno) << std::endl;
        ::close(sock);
        return 1;
    }

    sockaddr_in6 addr{};
    addr.sin6_family = AF_INET6;
    addr.sin6_addr = in6addr_any;
    addr.sin6_port = htons(static_cast<uint16_t>(port));

    if (::bind(sock, reinterpret_cast<sockaddr*>(&addr), sizeof(addr)) < 0) {
        std::cerr << "Failed to bind UDP socket on port " << port << ": " << std::strerror(errno) << std::endl;
        ::close(sock);
        return 1;
    }

    std::cout << "udp_frame_probe listening on [::]:" << port << " (dual stack)" << std::endl;

    mcu_comm::ProtocolParser parser;
    std::vector<uint8_t> buffer(2048);

    while (g_running) {
        sockaddr_storage peer{};
        socklen_t peerLen = sizeof(peer);
        ssize_t received = ::recvfrom(sock, buffer.data(), buffer.size(), 0,
                                      reinterpret_cast<sockaddr*>(&peer), &peerLen);
        if (received < 0) {
            if (errno == EINTR) {
                continue;
            }
            std::cerr << "recvfrom failed: " << std::strerror(errno) << std::endl;
            break;
        }

        std::vector<uint8_t> datagram(buffer.begin(), buffer.begin() + received);
        std::cout << "RX datagram bytes=" << received << " hex=" << bytesToHex(datagram) << std::endl;

        auto frames = parser.parse(datagram);
        if (frames.empty()) {
            std::cout << "No complete protocol frame parsed from datagram" << std::endl;
            continue;
        }

        for (const auto& frame : frames) {
            std::cout << "Frame pid=0x" << std::hex << std::uppercase << std::setw(2) << std::setfill('0')
                      << static_cast<int>(frame.pid)
                      << " mid=0x" << std::setw(2) << static_cast<int>(frame.mid)
                      << std::dec << " len=" << static_cast<int>(frame.len)
                      << " crc_ok=" << (frame.verifyCRC() ? "true" : "false")
                      << std::endl;

            if (frame.pid == static_cast<uint8_t>(mcu_comm::PacketID::CHASSIS_CTRL) && frame.data.size() >= 8) {
                const int16_t v = readInt16Le(frame.data, 0);
                const int16_t d = readInt16Le(frame.data, 2);
                const int16_t w = readInt16Le(frame.data, 4);
                const int16_t theta = readInt16Le(frame.data, 6);
                std::cout << "CHASSIS_CTRL decoded: v=" << (v / 1000.0f)
                          << " d=" << (d / 1000.0f)
                          << " w=" << (w / 1000.0f)
                          << " theta=" << (theta / 1000.0f)
                          << std::endl;
            }
        }
    }

    ::close(sock);
    return 0;
}
