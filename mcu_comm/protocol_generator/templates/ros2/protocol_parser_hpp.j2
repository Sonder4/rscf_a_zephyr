/* ============================================================================ */
/*                              字节序转换                                      */
/* ============================================================================ */

// 小端序协议，无需转换
template<typename T>
T hostToNetwork(T value) {
    return value;
}

template<typename T>
T networkToHost(T value) {
    return value;
}

// 浮点数字节序转换
inline float hostToNetworkFloat(float value) {
    uint32_t temp;
    static_assert(sizeof(temp) == sizeof(value), "Size mismatch");
    std::memcpy(&temp, &value, sizeof(temp));
    temp = hostToNetwork(temp);
    float result;
    std::memcpy(&result, &temp, sizeof(result));
    return result;
}

inline float networkToHostFloat(float value) {
    return hostToNetworkFloat(value);
}

