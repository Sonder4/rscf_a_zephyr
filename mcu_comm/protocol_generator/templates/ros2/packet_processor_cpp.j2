/*                              数据包提交                                      */
/* ============================================================================ */

bool PacketProcessor::submitPacket(PacketID pid, const PacketData& data) {
    if (!is_running_) {
        return false;
    }

    std::lock_guard<std::mutex> lock(processors_mutex_);
    auto it = pid_processors_.find(pid);
    if (it == pid_processors_.end()) {
        return false;
    }

    auto& processor = it->second;
    std::lock_guard<std::mutex> queue_lock(processor->queue_mutex);

    // 检查队列是否已满
    if (processor->data_queue.size() >= processor->max_queue_size) {
        return false;
    }

    processor->data_queue.push(data);
    processor->queue_cv.notify_one();

    return true;
}

