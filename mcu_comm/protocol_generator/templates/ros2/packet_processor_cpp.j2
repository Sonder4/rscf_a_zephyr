/* ============================================================================ */
/*                              PID处理线程主循环                               */
/* ============================================================================ */

void PacketProcessor::processPIDLoop(PacketID pid) {
    std::unique_ptr<PidProcessor>* processor_ptr = nullptr;

    {
        std::lock_guard<std::mutex> lock(processors_mutex_);
        auto it = pid_processors_.find(pid);
        if (it == pid_processors_.end()) {
            return;
        }
        processor_ptr = &it->second;
    }

    auto& processor = *processor_ptr;

    while (!processor->should_stop.load()) {
        PacketData data;

        {
            std::unique_lock<std::mutex> lock(processor->queue_mutex);
            processor->queue_cv.wait(lock, [&processor] {
                return !processor->data_queue.empty() || processor->should_stop.load();
            });

            if (processor->should_stop.load()) {
                break;
            }

            if (processor->data_queue.empty()) {
                continue;
            }

            data = std::move(processor->data_queue.front());
            processor->data_queue.pop();
        }

        // 查找并调用对应的处理函数
        auto handler_it = pid_handlers_.find(pid);
        if (handler_it != pid_handlers_.end()) {
            handler_it->second(data);
        }
    }
}

