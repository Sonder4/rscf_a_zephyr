/* ============================================================================ */
/*                              初始化/启动/停止                                */
/* ============================================================================ */

bool PacketProcessor::initialize() {
    if (!parser_) {
        std::cerr << "PacketProcessor: parser is null" << std::endl;
        return false;
    }

    // 预创建所有PID处理线程
    std::lock_guard<std::mutex> lock(processors_mutex_);
    for (const auto& config : pid_configs_) {
        auto processor = std::make_unique<PidProcessor>();
        processor->pid = config.pid;
        processor->max_queue_size = config.queue_size;
        processor->should_stop = false;
        pid_processors_[config.pid] = std::move(processor);
    }

    return true;
}

bool PacketProcessor::start() {
    if (is_running_) {
        return true;
    }

    std::lock_guard<std::mutex> lock(processors_mutex_);

    is_running_ = true;

    // 启动所有PID处理线程
    for (auto& [pid, processor] : pid_processors_) {
        processor->should_stop = false;
        processor->thread = std::thread(&PacketProcessor::processPIDLoop, this, pid);
    }

    return true;
}

void PacketProcessor::stop() {
    if (!is_running_) {
        return;
    }

    is_running_ = false;

    {
        std::lock_guard<std::mutex> lock(processors_mutex_);
        // 通知所有线程停止
        for (auto& [pid, processor] : pid_processors_) {
            processor->should_stop = true;
            processor->queue_cv.notify_all();
        }
    }

    // 等待所有线程结束
    std::lock_guard<std::mutex> lock(processors_mutex_);
    for (auto& [pid, processor] : pid_processors_) {
        if (processor->thread.joinable()) {
            processor->thread.join();
        }
    }
}

