/**
 * @file tcp_transport.hpp
 * @brief TCP 传输类头文件
 */

#ifndef MCU_COMM_TRANSPORT_TCP_TRANSPORT_HPP
#define MCU_COMM_TRANSPORT_TCP_TRANSPORT_HPP

#include <atomic>
#include <cstdint>
#include <functional>
#include <mutex>
#include <string>

#include "transport/transport_interface.hpp"

namespace mcu_comm {

class TcpTransport : public mcu_comm::ITransport {
public:
    explicit TcpTransport(const std::string& host = "192.168.1.10",
                          int port = 8899,
                          int timeout_ms = 1000,
                          bool no_delay = true);
    ~TcpTransport() override;

    bool connect() override;
    void disconnect() override;
    bool isConnected() const override;
    bool write(const uint8_t* data, size_t size) override;
    size_t read(uint8_t* buffer, size_t max_size) override;
    void setReadCallback(std::function<void(const uint8_t*, size_t)> callback) override;

private:
    bool configureSocket() const;
    void setLastError(const std::string& error);

    int socket_fd_;
    std::string host_;
    int port_;
    int timeout_ms_;
    bool no_delay_;
    std::atomic<bool> connected_;
    std::function<void(const uint8_t*, size_t)> read_callback_;
    mutable std::mutex error_mutex_;
    std::string last_error_;
};

}  // namespace mcu_comm

#endif  // MCU_COMM_TRANSPORT_TCP_TRANSPORT_HPP
