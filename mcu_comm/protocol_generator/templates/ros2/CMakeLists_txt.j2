cmake_minimum_required(VERSION 3.8)
project(mcu_comm)

if(CMAKE_COMPILER_IS_GNUCXX OR CMAKE_CXX_COMPILER_ID MATCHES "Clang")
  add_compile_options(-Wall -Wextra -Wpedantic)
endif()

# find dependencies
find_package(ament_cmake REQUIRED)
find_package(ament_cmake_gtest REQUIRED)
find_package(rclcpp REQUIRED)
find_package(rclcpp_action REQUIRED)
find_package(std_msgs REQUIRED)
find_package(sensor_msgs REQUIRED)
find_package(nav_msgs REQUIRED)
find_package(geometry_msgs REQUIRED)
find_package(rosidl_default_generators REQUIRED)

# Generate ROS2 messages
rosidl_generate_interfaces(${PROJECT_NAME}
{% for packet in packets %}
  "msg/{{ packet.name | to_pascal_case }}.msg"
{% endfor %}
{% for service in control_plane.services %}
  "srv/{{ service.pascal_name }}.srv"
{% endfor %}
{% for action in control_plane.actions %}
  "action/{{ action.pascal_name }}.action"
{% endfor %}
  DEPENDENCIES std_msgs sensor_msgs nav_msgs geometry_msgs
)

# SOULDE USB2CAN SDK path
set(SOULDE_USB2CAN_ROOT "${CMAKE_CURRENT_SOURCE_DIR}/third_party/soulde_usb2can")
if(NOT EXISTS "${SOULDE_USB2CAN_ROOT}/include/usb_can.h")
  set(SOULDE_USB2CAN_ROOT "${CMAKE_CURRENT_SOURCE_DIR}/ros2_package/third_party/soulde_usb2can")
endif()

# Include directories
include_directories(
  include
  msg
  ${SOULDE_USB2CAN_ROOT}/include
)

add_library(soulde_usb2can SHARED IMPORTED GLOBAL)
set_target_properties(soulde_usb2can PROPERTIES
  IMPORTED_LOCATION "${SOULDE_USB2CAN_ROOT}/lib/libusb_can.so"
  INTERFACE_INCLUDE_DIRECTORIES "${SOULDE_USB2CAN_ROOT}/include"
)

# Create library
add_library(${PROJECT_NAME}_lib SHARED
  src/protocol/protocol_parser.cpp
  src/manager/comm_manager.cpp
  src/transport/can_transport.cpp
  src/transport/serial_transport.cpp
  src/transport/tcp_transport.cpp
  src/node/mcu_comm_node.cpp
)

ament_target_dependencies(${PROJECT_NAME}_lib
  rclcpp
  rclcpp_action
  std_msgs
  sensor_msgs
  nav_msgs
  geometry_msgs
)

rosidl_get_typesupport_target(cpp_typesupport_target ${PROJECT_NAME} "rosidl_typesupport_cpp")
target_link_libraries(${PROJECT_NAME}_lib "${cpp_typesupport_target}")
target_link_libraries(${PROJECT_NAME}_lib soulde_usb2can)

# Create executable
add_executable(${PROJECT_NAME}_node src/node/main.cpp)
target_link_libraries(${PROJECT_NAME}_node ${PROJECT_NAME}_lib)
ament_target_dependencies(${PROJECT_NAME}_node
  rclcpp
  rclcpp_action
  std_msgs
  sensor_msgs
  nav_msgs
  geometry_msgs
)

add_executable(udp_frame_probe src/tools/udp_frame_probe.cpp)
target_link_libraries(udp_frame_probe ${PROJECT_NAME}_lib)

# Install targets
install(TARGETS ${PROJECT_NAME}_lib
  ARCHIVE DESTINATION lib
  LIBRARY DESTINATION lib
  RUNTIME DESTINATION bin
)

install(TARGETS ${PROJECT_NAME}_node
  DESTINATION lib/${PROJECT_NAME}
)

install(TARGETS udp_frame_probe
  DESTINATION lib/${PROJECT_NAME}
)

# Install include directory
install(DIRECTORY include/
  DESTINATION include
)

# Install launch files (if any)
install(DIRECTORY launch
  DESTINATION share/${PROJECT_NAME}
  OPTIONAL
)

# Install config files (if any)
install(DIRECTORY config
  DESTINATION share/${PROJECT_NAME}
  OPTIONAL
)

ament_export_include_directories(include)
ament_export_libraries(${PROJECT_NAME}_lib)

if(BUILD_TESTING)
  ament_add_gtest(test_comm_manager_connection_state
    test/test_comm_manager_connection_state.cpp
  )
  if(TARGET test_comm_manager_connection_state)
    target_link_libraries(test_comm_manager_connection_state ${PROJECT_NAME}_lib)
    ament_target_dependencies(test_comm_manager_connection_state
      rclcpp
      rclcpp_action
      std_msgs
      sensor_msgs
      nav_msgs
      geometry_msgs
    )
  endif()
endif()

ament_package()
