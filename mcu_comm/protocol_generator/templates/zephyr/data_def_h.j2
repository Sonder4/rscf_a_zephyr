#ifndef __DATA_DEF_H
#define __DATA_DEF_H

#include <stdint.h>
#include <string.h>

typedef enum
{
{% for pc in device_config.pc_hosts %}
    {{ pc.name }} = {{ pc.mid }},    /* {{ pc.description }} */
{% endfor %}
{% for mcu in device_config.mcu_devices %}
    {{ mcu.name }} = {{ mcu.mid }}{% if not loop.last %},{% endif %}    /* {{ mcu.description }} */
{% endfor %}
} DeviceID_t;

{% for enum_name, enum_info in control_plane.enums.items() %}
typedef enum
{
{% for entry in enum_info.entries %}
    CONTROL_PLANE_{{ enum_name | to_upper_snake }}_{{ entry.name | to_upper_snake }} = {{ entry.value }}{% if not loop.last %},{% endif %}    /* {{ enum_info.description }} */
{% endfor %}
} ControlPlane{{ enum_name | to_pascal_case }}_e;

{% endfor %}

{% for packet in packets %}
#define PID_{{ packet.name | to_upper_snake }}        {{ packet.pid }}    /* {{ packet.description }} */
{% endfor %}

{% for control_packet in packets if control_packet.control_plane_fields is defined %}
#define {{ control_packet.name | to_upper_snake }}_NUM_BYTES              {{ control_packet.control_plane_num_bytes }}U
{% for field in control_packet.control_plane_fields %}
#define {{ control_packet.name | to_upper_snake }}_{{ field.name | to_upper_snake }}_OFFSET          {{ field.bit_offset }}U
#define {{ control_packet.name | to_upper_snake }}_{{ field.name | to_upper_snake }}_WIDTH           {{ field.bit_width }}U
#define {{ control_packet.name | to_upper_snake }}_{{ field.name | to_upper_snake }}_SYNC_DIRECTION  {{ field.sync_direction_macro }}
#define {{ control_packet.name | to_upper_snake }}_{{ field.name | to_upper_snake }}_APPLY_MODE      {{ field.apply_mode_macro }}
{% endfor %}
{% endfor %}

#pragma pack(1)
{% for packet in packets %}
typedef struct
{
{% if packet.control_plane_fields is defined %}
    uint8_t {{ packet.control_plane_bytes_field_name }}[{{ packet.name | to_upper_snake }}_NUM_BYTES];
{% else %}
{% for field in packet.data_fields %}
    {{ type_mapping[field.type].c_type }} {{ field.name }};
{% endfor %}
{% endif %}
} {{ packet.name | to_camel_case }}_t;

{% endfor %}
#pragma pack()

typedef void (*PID_Callback_t)(void* data);

typedef struct
{
    uint8_t target_mid;
    uint8_t data_len;
    PID_Callback_t callback;
    void* data_ptr;
} PID_Entry_t;

extern PID_Entry_t pid_registry[256];

{% for packet in packets %}
extern {{ packet.name | to_camel_case }}_t g_{{ packet.name | to_snake_case }};
{% endfor %}

void PID_Registry_Init(void);
void PID_RegisterCallback(uint8_t pid, PID_Callback_t callback);

{% for packet in packets %}
uint16_t {{ packet.name | to_snake_case }}_serialize(const {{ packet.name | to_camel_case }}_t* data, uint8_t* buf);

{% endfor %}

#endif /* __DATA_DEF_H */
