/********************************包含头文件************************************/
#include "data_def.h"
#include <string.h>

/********************************全局数据结构体实例************************************/

{% for packet in packets %}
{{ packet.name | to_camel_case }}_t g_{{ packet.name | to_snake_case }};
{% endfor %}

/********************************PID注册表数组************************************/

PID_Entry_t pid_registry[256];

/********************************PID注册表初始化************************************/

void PID_Registry_Init(void)
{
    memset(pid_registry, 0, sizeof(pid_registry));
    
{% for packet in packets %}
    pid_registry[PID_{{ packet.name | to_upper_snake }}].target_mid = {{ packet | get_target_mid(mcu_mid) }};
    pid_registry[PID_{{ packet.name | to_upper_snake }}].data_len = sizeof({{ packet.name | to_camel_case }}_t);
    pid_registry[PID_{{ packet.name | to_upper_snake }}].callback = NULL;
    pid_registry[PID_{{ packet.name | to_upper_snake }}].data_ptr = &g_{{ packet.name | to_snake_case }};
    
{% endfor %}
}

void PID_RegisterCallback(uint8_t pid, PID_Callback_t callback)
{
    pid_registry[pid].callback = callback;
}

/********************************序列化函数（小端序，直接拷贝）************************************/

{% for packet in packets %}
uint16_t {{ packet.name | to_snake_case }}_serialize(const {{ packet.name | to_camel_case }}_t* data, uint8_t* buf)
{
    memcpy(buf, data, sizeof({{ packet.name | to_camel_case }}_t));
    return sizeof({{ packet.name | to_camel_case }}_t);
}

{% endfor %}

