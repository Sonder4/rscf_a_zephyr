{% if packet.control_plane_fields is defined %}
bool RobotSend{{ packet.name | to_pascal_case }}(const uint8_t *control_plane_bytes) {
  {{ packet.name | to_camel_case }}_t data;

  if (!g_is_initialized) {
    return false;
  }
  memset(data.{{ packet.control_plane_bytes_field_name }}, 0, sizeof(data.{{ packet.control_plane_bytes_field_name }}));

  if (control_plane_bytes != NULL) {
    memcpy(data.{{ packet.control_plane_bytes_field_name }},
           control_plane_bytes,
           sizeof(data.{{ packet.control_plane_bytes_field_name }}));
  }

  Comm_Send(DEVICE_MID, PID_{{ packet.name | to_upper_snake }}, (uint8_t*)&data, sizeof(data));
  return true;
}

{% else %}
bool RobotSend{{ packet.name | to_pascal_case }}({% for field in packet.data_fields %}{{ type_mapping[field.type].c_type }} {{ field.name }}{% if not loop.last %}, {% endif %}{% endfor %}) {
  if (!g_is_initialized) {
    return false;
  }

  {{ packet.name | to_camel_case }}_t data;
{% for field in packet.data_fields %}
  data.{{ field.name }} = {{ field.name }};
{% endfor %}

  Comm_Send(DEVICE_MID, PID_{{ packet.name | to_upper_snake }}, (uint8_t*)&data, sizeof(data));
  return true;
}

