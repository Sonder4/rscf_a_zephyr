/**********************************************************************
  * @ 函数名  ： RobotSend{{ packet.name | to_pascal_case }}
  * @ 功能说明： 发送{{ packet.description }}
  * @ 参数    ： {% if packet.control_plane_fields is defined %}control_plane_bytes: 固定长度控制面原始字节数组{% else %}{% for field in packet.data_fields %}{{ field.name }}: {{ field.description }}{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}
