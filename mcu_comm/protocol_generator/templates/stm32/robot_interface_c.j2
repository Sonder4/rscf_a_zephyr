#if MCU_COMM_DEBUG_TRACE
/**********************************************************************
  * @ 函数名  ： FloatToU32Bits
  * @ 功能说明： 将浮点数按位解释为32位无符号整数，便于RTT十六进制日志输出
  * @ 参数    ： value：输入浮点数
  * @ 返回值  ： uint32_t位模式
  ********************************************************************/
static uint32_t FloatToU32Bits(float value) {
  uint32_t bits = 0;
  memcpy(&bits, &value, sizeof(bits));
  return bits;
}

/**********************************************************************
  * @ 函数名  ： RobotDebugTraceTxTick
  * @ 功能说明： 调试模式下周期发送全量MCU->PC数据包，便于ROS2链路验收
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
static void RobotDebugTraceTxTick(void) {
  static uint32_t s_last_tick = 0;
  static uint16_t s_counter = 0;
  uint32_t now = RobotInterfaceGetTickMs();

  if ((uint32_t)(now - s_last_tick) < 200u) {
    return;
  }
  s_last_tick = now;
  s_counter++;

  {% for packet in packets %}
  {% if packet.name == 'CHASSIS_FEEDBACK' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  {
    float base = ((float)(s_counter % 100u)) * 0.01f;
    RobotSendChassisFeedback(0.2f + base,
                             -0.1f + 0.5f * base,
                             (float)((int32_t)s_counter * 15),
                             (float)(-(int32_t)s_counter * 9));
  }
  {% endif %}
  {% if packet.name == 'MOTOR_DATA' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  {
    float base = ((float)(s_counter % 100u)) * 0.01f;
    RobotSendMotorData(1.0f + base,
                       0.5f + 0.2f * base,
                       0.1f + 0.05f * base,
                       (uint8_t)(s_counter % 8u));
  }
  {% endif %}
  {% if packet.name == 'IMU_EULER' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  RobotSendImuEuler(0.001f * (float)(s_counter % 1000u), 0.2f, -0.15f);
  {% endif %}
  {% if packet.name == 'IMU_QUATERNION' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  {
    float q1 = 0.01f * (float)(s_counter % 10u);
    float q2 = 0.02f * (float)(s_counter % 10u);
    float q3 = 0.03f * (float)(s_counter % 10u);
    RobotSendImuQuaternion(1.0f, q1, q2, q3);
    LOGINFO("[ri] TX debug #%lu q=[0x%08lX,0x%08lX,0x%08lX,0x%08lX]",
            (unsigned long)s_counter,
            (unsigned long)FloatToU32Bits(1.0f),
            (unsigned long)FloatToU32Bits(q1),
            (unsigned long)FloatToU32Bits(q2),
            (unsigned long)FloatToU32Bits(q3));
  }
  {% endif %}
  {% if packet.name == 'SYSTEM_STATUS' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  {
    uint8_t status_bytes[SYSTEM_STATUS_NUM_BYTES] = {0};
    status_bytes[0] = (uint8_t)(s_counter & 0x03u);
    RobotSendSystemStatus(status_bytes);
  }
  {% endif %}
  {% endfor %}
}
#endif

/********************************自定义函数************************************/

/**********************************************************************
  * @ 函数名  ： RobotInterfaceInit
  * @ 功能说明： 初始化机器人接口
  * @ 参数    ： 无
  * @ 返回值  ： true表示成功
  ********************************************************************/
bool RobotInterfaceInit(void) {
  if (g_is_initialized) {
    return true;
  }

  /* 初始化PID注册表 */
  PID_Registry_Init();

  /* 初始化通信管理器（默认transport由生成宏决定） */
  Comm_Init(NULL);

  /* 注册PID对应的回调函数 */
{% for packet in packets %}
{% if packet.direction == 'pc_to_mcu' or packet.direction == 'bidirectional' %}
  PID_RegisterCallback(PID_{{ packet.name | to_upper_snake }}, {{ packet.name | to_pascal_case }}Callback);
{% endif %}
{% endfor %}

  g_is_initialized = true;
  return true;
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceDeinit
  * @ 功能说明： 反初始化机器人接口
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceDeinit(void) {
  g_is_initialized = false;
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceBindTxTask
  * @ 功能说明： 绑定通信 TX 任务句柄，供事件补发使用
  * @ 参数    ： task_handle: TX 任务句柄
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceBindTxTask(TaskHandle_t task_handle) {
  s_robot_tx_task_handle = task_handle;
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceRequestTxEvent
  * @ 功能说明： 请求 TX 任务尽快发送事件型报文
  * @ 参数    ： tx_events: 事件位掩码
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceRequestTxEvent(uint32_t tx_events) {
  if (s_robot_tx_task_handle == NULL) {
    return;
  }

  (void)xTaskNotify(s_robot_tx_task_handle, tx_events, eSetBits);
}

