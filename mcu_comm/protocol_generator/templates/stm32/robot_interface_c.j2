/**********************************************************************
  * @ 函数名  ： RobotInterfaceTestTick
  * @ 功能说明： 测试模式下周期发送固定测试报文
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceTestTick(void) {
#if MCU_COMM_TEST_MODE
  static uint32_t s_last_tick = 0;
  static uint16_t s_counter = 0;
  uint32_t now = RobotInterfaceGetTickMs();

  if (!g_is_initialized) {
    return;
  }

  if ((uint32_t)(now - s_last_tick) < MCU_COMM_TEST_INTERVAL_MS) {
    return;
  }
  s_last_tick = now;
  s_counter++;

  {% for packet in packets %}
  {% if packet.name == 'CHASSIS_FEEDBACK' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  RobotSendChassisFeedback(0.5f + 0.01f * (float)(s_counter % 20),
                           -0.2f,
                           (float)(s_counter * 10),
                           -(float)(s_counter * 5));
  {% endif %}
  {% if packet.name == 'IMU_EULER' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  RobotSendImuEuler(0.1f, 0.2f, 0.01f * (float)(s_counter % 314));
  {% endif %}
  {% if packet.name == 'SYSTEM_STATUS' and (packet.direction == 'mcu_to_pc' or packet.direction == 'bidirectional') %}
  {
    uint8_t status_bytes[SYSTEM_STATUS_NUM_BYTES] = {0};
    status_bytes[0] = (uint8_t)(s_counter & 0x03u);
    RobotSendSystemStatus(status_bytes);
  }
  {% endif %}
  {% endfor %}
#endif
}

/* ============================================================================ */
/*                              回调函数默认实现（弱符号）                        */
/* ============================================================================ */

{% for packet in packets %}
{% if packet.direction == 'pc_to_mcu' or packet.direction == 'bidirectional' %}
__attribute__((weak)) void {{ packet.name | to_pascal_case }}Callback(void* data) {
  /* 默认实现为空，用户可覆盖此函数 */
  /* 数据已存储在 g_{{ packet.name | to_snake_case }} 中 */
  {% if packet.name == 'MOTOR_DATA' %}
  const {{ packet.name | to_camel_case }}_t* motor_data = (const {{ packet.name | to_camel_case }}_t*)data;

  if (motor_data == NULL) {
    motor_data = &g_{{ packet.name | to_snake_case }};
  }
  {% elif packet.name == 'ROBOT_SWITCH' %}
  const {{ packet.name | to_camel_case }}_t* robot_switch = (const {{ packet.name | to_camel_case }}_t*)data;

  if (robot_switch == NULL) {
    robot_switch = &g_{{ packet.name | to_snake_case }};
  }
  {% else %}
  (void)data;
  {% endif %}

  /* USER CODE BEGIN {{ packet.name | to_pascal_case }}Callback */
  {% if packet.name == 'MOTOR_DATA' %}
#if MCU_COMM_DEBUG_TRACE
  static uint32_t s_cb_count = 0;
  s_cb_count++;
  LOGINFO("[ri] MotorData cb#%lu motor=%u speed=0x%08lX pos=0x%08lX torque=0x%08lX",
          (unsigned long)s_cb_count,
          motor_data->motor_num,
          (unsigned long)FloatToU32Bits(motor_data->speed_rads),
          (unsigned long)FloatToU32Bits(motor_data->position_rad),
          (unsigned long)FloatToU32Bits(motor_data->torque_nm));
#endif
  {% elif packet.name == 'ROBOT_SWITCH' %}
#if MCU_COMM_DEBUG_TRACE
  static uint32_t s_cb_count = 0;
  s_cb_count++;
  LOGINFO("[ri] RobotSwitch cb#%lu mask=0x%04X",
          (unsigned long)s_cb_count,
          robot_switch->switch_mask);
#endif
  {% endif %}

  /* USER CODE END {{ packet.name | to_pascal_case }}Callback */
}

{% endif %}
{% endfor %}
/**********************************************************************
  * @ 函数名  ： RobotInterfaceProcess
  * @ 功能说明： 主循环处理函数
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceProcess(void) {
  if (!g_is_initialized) {
    return;
  }

  RobotInterfaceProcessRx();
  RobotInterfaceProcessTxPeriodic();
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceProcessRx
  * @ 功能说明： 仅处理通信接收方向的数据解析与回调
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceProcessRx(void) {
  if (!g_is_initialized) {
    return;
  }

  Comm_ProcessRx();
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceProcessTxPeriodic
  * @ 功能说明： 周期发送底盘/状态等上行报文
  * @ 参数    ： 无
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceProcessTxPeriodic(void) {
  if (!g_is_initialized) {
    return;
  }

  Comm_Batch_Begin();

#if defined(ONE_BOARD) || defined(CHASSIS_BOARD)
  ChassisCommPublishTick();
#endif

#if defined(ONE_BOARD) || defined(GIMBAL_BOARD) || defined(CHASSIS_BOARD)
  RobotCmdCommPublishTick();
#endif

  Comm_Batch_End();

#if MCU_COMM_DEBUG_TRACE
  /* 调试验收阶段，周期发送全量MCU->PC包用于ROS2解析验证 */
  RobotDebugTraceTxTick();
#endif
}

/**********************************************************************
  * @ 函数名  ： RobotInterfaceProcessTxEvent
  * @ 功能说明： 处理事件型补发报文
  * @ 参数    ： tx_events: 事件位掩码
  * @ 返回值  ： 无
  ********************************************************************/
void RobotInterfaceProcessTxEvent(uint32_t tx_events) {
  if (!g_is_initialized) {
    return;
  }

  if ((tx_events & ROBOT_INTERFACE_TX_EVENT_SYSTEM_STATUS) != 0U) {
#if defined(ONE_BOARD) || defined(GIMBAL_BOARD) || defined(CHASSIS_BOARD)
    RobotCmdCommPublishNow();
#endif
  }
}

/**********************************************************************
  * @ 函数名  ： RobotIsConnected
  * @ 功能说明： 获取通信连接状态
  * @ 参数    ： 无
  * @ 返回值  ： true表示已连接
  ********************************************************************/
bool RobotIsConnected(void) {
  if (!g_is_initialized) {
    return false;
  }
  return Comm_IsConnected();
}

bool RobotRxOverflowed(void) {
  if (!g_is_initialized) {
    return false;
  }
  return Comm_HasRxOverflow();
}

